    <!-- ========== 接続矢印: アプリ層 → ミドルウェア層 ========== -->
    <!-- usb_host → TinyUSB Host -->
    <!-- usb_host: x=1060-1180, 中央x=1120, 下端y=200 -->
    <!-- TinyUSB: x=950-1100, 中央x=1025, 上端y=350 -->
    <!-- 層間余白 y=240〜310、矢印はy=275付近を通過 -->
    <mxCell id="610" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="270" target="310">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ========== 接続矢印: ミドルウェア層 → HAL層 ========== -->
    <!-- TinyUSB Host → Pico SDK USB -->
    <!-- TinyUSB: x=950-1100, 中央x=1025, 下端y=410 -->
    <!-- Pico SDK USB: x=590-740, 中央x=665, 上端y=555 -->
    <!-- 層間余白 y=430〜510。右側から左に折れて接続する。 -->
    <mxCell id="620" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="310" target="430">
