    <mxCell id="904" value="■ オレンジ系: ハードウェア層" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="340" y="920" width="240" height="20" as="geometry" />
