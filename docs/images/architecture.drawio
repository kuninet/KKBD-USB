    <mxCell id="905" value="━▶ 矢印 = 依存関係（呼び出し方向）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
