          <mxPoint x="875" y="520" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- uart_monitor → Pico SDK UART（Phase 9）:
         uart_monitor下端(x=1280, y=210) → 真下に下り → x=1380(右外側) → y=480 → Pico SDK UART上端(x=455, y=555)
