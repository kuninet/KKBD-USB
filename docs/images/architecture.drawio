          <mxPoint x="665" y="470" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ========== 接続矢印: アプリ層 → HAL層（直接） ========== -->
    <!-- 層間余白: アプリ層下端 y=240、ミドルウェア上端 y=310、ミドルウェア下端 y=430、HAL上端 y=510 -->
    <!-- アプリ→HAL直接矢印はミドルウェア層の「右端外側」（x=1130付近）を迂回させる -->

    <!-- uart_out → Pico SDK UART -->
    <!-- uart_out: x=900-1020, 中央x=960, 下端y=200 -->
    <!-- Pico SDK UART: x=380-530, 中央x=455, 上端y=555 -->
    <!-- 迂回ルート: uart_out下端 → x=1140(ミドルウェア右外側) → y=470(ミドルウェア下端外) → Pico SDK UART上端 -->
    <mxCell id="630" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="260" target="420">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="960" y="270" />
          <mxPoint x="1150" y="270" />
          <mxPoint x="1150" y="490" />
          <mxPoint x="455" y="490" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- config → Pico SDK GPIO -->
    <!-- config: x=740-860, 中央x=800, 下端y=200 -->
    <!-- Pico SDK GPIO: x=110-260, 中央x=185, 上端y=555 -->
    <!-- 迂回ルート: config下端 → x=1155(ミドルウェア右外側、少しずらす) → y=480 → Pico SDK GPIO上端 -->
    <mxCell id="631" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="250" target="410">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="800" y="260" />
          <mxPoint x="1160" y="260" />
          <mxPoint x="1160" y="500" />
          <mxPoint x="185" y="500" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- led → Pico SDK GPIO -->
    <!-- led: x=580-700, 中央x=640, 下端y=200 -->
    <!-- Pico SDK GPIO: x=110-260, 中央x=185, 上端y=555 -->
    <!-- 迂回ルート: led下端 → x=1165(ミドルウェア右外側) → y=510 → Pico SDK GPIO上端 -->
    <mxCell id="632" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="240" target="410">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="640" y="250" />
          <mxPoint x="1170" y="250" />
          <mxPoint x="1170" y="510" />
          <mxPoint x="185" y="510" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- keyrepeat → Pico SDK Timer -->
    <!-- keyrepeat: x=420-540, 中央x=480, 下端y=200 -->
    <!-- Pico SDK Timer: x=800-950, 中央x=875, 上端y=555 -->
    <!-- 迂回ルート: keyrepeat下端 → x=1175(ミドルウェア右外側) → y=480 → Pico SDK Timer上端 -->
    <mxCell id="633" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="230" target="440">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="480" y="240" />
          <mxPoint x="1180" y="240" />
          <mxPoint x="1180" y="520" />
          <mxPoint x="875" y="520" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ========== 接続矢印: HAL層 → ハードウェア層 ========== -->
    <!-- 各矢印は箱の下端から垂直に下り、ハードウェア層の箱の上端に入る -->
    <!-- HAL層下端 y=640、ハードウェア層上端 y=730 → 間隔 90px、矢印が通るスペース十分 -->

    <!-- Pico SDK GPIO → RP2040 GPIO -->
    <!-- Pico SDK GPIO: x=110-260, 中央x=185, 下端y=615 -->
    <!-- RP2040 GPIO: x=590-740, 中央x=665, 上端y=770 -->
    <mxCell id="640" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="410" target="530">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="185" y="680" />
          <mxPoint x="665" y="680" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Pico SDK UART → RP2040 UART -->
    <!-- Pico SDK UART: x=380-530, 中央x=455, 下端y=615 -->
    <!-- RP2040 UART: x=380-530, 中央x=455, 上端y=770 -->
    <mxCell id="641" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="420" target="520">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- Pico SDK USB → RP2040 USB Host Controller -->
    <!-- Pico SDK USB: x=590-740, 中央x=665, 下端y=615 -->
    <!-- RP2040 USB: x=110-280, 中央x=195, 上端y=770 -->
    <mxCell id="642" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="430" target="510">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="665" y="690" />
          <mxPoint x="195" y="690" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Pico SDK Timer → RP2040 Timer -->
    <!-- Pico SDK Timer: x=800-950, 中央x=875, 下端y=615 -->
    <!-- RP2040 Timer: x=800-950, 中央x=875, 上端y=770 -->
    <mxCell id="643" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="440" target="540">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ========== 凡例（右下の余白に配置: ハードウェア層の右下、矢印が通らない位置） ========== -->
    <mxCell id="900" value="凡例" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=12;fontStyle=1;verticalAlign=top;arcSize=5;" vertex="1" parent="1">
