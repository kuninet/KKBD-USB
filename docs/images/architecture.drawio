    <!-- ========== 接続矢印: main → 各モジュール（アプリ層内） ========== -->
    <!--
      各モジュール箱の座標:
        main:      x=100-220, y=120-200  中央(160, 160)
        keymap:    x=260-380, y=120-200  中央(320, 160)
        keyrepeat: x=420-540, y=120-200  中央(480, 160)
        led:       x=580-700, y=120-200  中央(640, 160)
        config:    x=740-860, y=120-200  中央(800, 160)
        uart_out:  x=900-1020, y=120-200 中央(960, 160)
        usb_host:  x=1060-1180, y=120-200 中央(1120, 160)
      アプリ層下余白: y=200（箱下端）〜 y=240（層下端）→ 余白40px
      矢印は箱の下端(y=200)から出て、層の下余白(y=215, 220, 225, 230)を水平に通り、各箱の下端に入る
      各矢印を異なるy座標で通すことで矢印同士の重なりも防ぐ
    -->

    <!-- main → keymap: 隣接しているため右端→左端の水平接続（問題なし） -->
    <mxCell id="601" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="210" target="220">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- main → keyrepeat: main下端(y=200) → y=217(層下余白) → keyrepeat下端(y=200) -->
    <mxCell id="602" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="210" target="230">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="160" y="217" />
          <mxPoint x="480" y="217" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- main → led: main下端(y=200) → y=222(層下余白) → led下端(y=200) -->
    <mxCell id="603" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="210" target="240">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="160" y="222" />
          <mxPoint x="640" y="222" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- main → config: main下端(y=200) → y=227(層下余白) → config下端(y=200) -->
    <mxCell id="604" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="210" target="250">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="160" y="227" />
          <mxPoint x="800" y="227" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- main → uart_out: main下端(y=200) → y=232(層下余白) → uart_out下端(y=200) -->
    <mxCell id="605" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;endArrow=block;endFill=1;strokeWidth=1.5;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="210" target="260">
      <mxGeometry relative="1" as="geometry">
