    <mxCell id="901" value="■ 青系: アプリケーション層" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="100" y="895" width="220" height="20" as="geometry" />
