    </mxCell>

    <!-- led → Pico SDK GPIO:
         led下端(x=640, y=200) → x=1370 → y=510 → Pico SDK GPIO上端(x=185, y=555) -->
    <mxCell id="632" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="240" target="410">
