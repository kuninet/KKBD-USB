    -->

    <!-- uart_out → Pico SDK UART:
         uart_out下端(x=960, y=200) → x=1360(右外側) → y=490(HAL上) → Pico SDK UART上端(x=455, y=555) -->
    <mxCell id="630" value="呼び出し" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;fontColor=#666666;fontStyle=2;fontSize=10;labelBackgroundColor=#ffffff;endArrow=block;endFill=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="260" target="420">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
